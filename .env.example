# ============================================================
#  .env.example — Environment Variable Template
#  Day 10: Docker & Containerization
# ============================================================
#
#  This is the SAFE version to commit to Git.
#  Copy this file to .env and fill in real values:
#    cp .env.example .env
#
#  Never commit .env to version control!
# ============================================================

# PostgreSQL
POSTGRES_DB=cineversedb
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Spring Boot DataSource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cineversedb
SPRING_DATASOURCE_USERNAME=your_postgres_user
SPRING_DATASOURCE_PASSWORD=your_postgres_password
JPA_DDL_AUTO=create-drop

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password

# MongoDB
MONGO_INITDB_ROOT_USERNAME=your_mongo_user
MONGO_INITDB_ROOT_PASSWORD=your_mongo_password
MONGO_INITDB_DATABASE=cineverse_movies

# Ports
BOOKING_SERVICE_PORT=8080
FRONTEND_PORT=3000
RABBITMQ_MANAGEMENT_PORT=15672
POSTGRES_PORT=5432
REDIS_PORT_HOST=6379
MONGO_PORT=27017
