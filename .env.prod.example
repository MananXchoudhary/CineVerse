# ============================================================
#  .env.prod.example — Production Environment Template
#  Day 11: CI/CD & Cloud Deployment
# ============================================================
#
#  Academic Insight: Production Configuration
#  Production configs differ from development:
#  - Stronger passwords (random, long strings)
#  - Different DB names
#  - Real domain names
#  - No debug settings
#
#  Copy to .env.prod and fill in real values:
#    cp .env.prod.example .env.prod
#  NEVER commit .env.prod to Git!
# ============================================================

# ── DockerHub ────────────────────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username

# ── PostgreSQL (Production) ──────────────────────────────────
POSTGRES_DB=cineversedb_prod
POSTGRES_USER=cineverse_prod_user
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here

# ── Spring Boot DataSource ────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cineversedb_prod
SPRING_DATASOURCE_USERNAME=cineverse_prod_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_random_password_here
SPRING_PROFILES_ACTIVE=prod

# ── Redis (Production — with password) ──────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# ── RabbitMQ (Production) ────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=cineverse_prod
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_strong_password

# ── MongoDB (Production) ─────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=cineverse_prod
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_mongo_strong_password
MONGO_INITDB_DATABASE=cineverse_movies_prod

# ── Domain (for SSL certificate) ────────────────────────────
DOMAIN=yourdomain.com
