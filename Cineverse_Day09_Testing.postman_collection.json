{
  "info": {
    "name": "Cineverse Day 09 Testing & Validation",
    "description": "Complete API Test Collection for Cineverse Backend — Day 09 Testing & Validation.\nCovers: happy path, edge cases, error handling, status codes, response structure.\nRun against: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Booking — Happy Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Status code is 200 OK",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test: Response contains an id (bookingId)",
              "pm.test('Response contains bookingId', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.id).to.not.be.null;",
              "});",
              "",
              "// Test: Booking status is CONFIRMED",
              "pm.test('Booking status is CONFIRMED', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('CONFIRMED');",
              "});",
              "",
              "// Test: showId matches request",
              "pm.test('showId matches request', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.showId).to.eql('SH1');",
              "});",
              "",
              "// Save bookingId for downstream tests",
              "if (pm.response.json().id) {",
              "    pm.environment.set('bookingId', pm.response.json().id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"showId\": \"SH1\",\n  \"seatIds\": [\"A1\", \"A2\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Booking — Empty Seat List (Edge Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Status code is 400 Bad Request",
              "pm.test('Status code is 400 for empty seats', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "// Test: Error message is returned",
              "pm.test('Error message is present', function () {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.include('Seat list cannot be empty');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"showId\": \"SH2\",\n  \"seatIds\": []\n}"
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "3. Create Booking — Invalid / Missing ShowId (Edge Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Status code is 400 Bad Request",
              "pm.test('Status code is 400 for invalid showId', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "// Test: Response body contains error",
              "pm.test('Response contains error message', function () {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"showId\": \"\",\n  \"seatIds\": [\"A1\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "4. Create Booking — Concurrent Double Booking (Same Seat)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Academic Insight: Race condition test — booking the same seat twice.",
              "// First booking should succeed (200), second should fail (400).",
              "// In a real Redis setup, SET NX prevents double-booking atomically.",
              "",
              "// NOTE: This request is the SECOND booking for seat A1.",
              "// Run test 1 first to lock seat A1, then run this test.",
              "",
              "pm.test('Double booking returns 400 (seat already taken)', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Seat already booked error message', function () {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.include('already booked');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"showId\": \"SH1\",\n  \"seatIds\": [\"A1\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "5. Create Booking — Null Body (Edge Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Server handles malformed request",
              "pm.test('Status is 400 for null/malformed body', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 415, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    },
    {
      "name": "6. Validate Response Structure",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Status 200",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test: Response time is acceptable",
              "pm.test('Response time is less than 500ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "// Test: Content-Type is JSON",
              "pm.test('Content-Type is application/json', function () {",
              "    pm.response.to.have.header('Content-Type');",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "// Test: All required fields exist",
              "pm.test('Response has all required fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('showId');",
              "    pm.expect(json).to.have.property('seatIds');",
              "    pm.expect(json).to.have.property('status');",
              "});",
              "",
              "// Test: seatIds is an array",
              "pm.test('seatIds is an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.seatIds).to.be.an('array');",
              "    pm.expect(json.seatIds.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"showId\": \"SH3\",\n  \"seatIds\": [\"C1\", \"C2\", \"C3\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/booking",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["booking"]
        }
      },
      "response": []
    }
  ]
}
